# ─── Supabase ────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Anthropic ────────────────────────────────────────────────
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── RentCast ────────────────────────────────────────────────
# Get this from: app.rentcast.io → API Dashboard
# Free tier: 50 calls/month (enough for beta)
# Paid: $29/mo for 500 calls/mo
RENTCAST_API_KEY=your_rentcast_key_here

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Osooley
